{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ax-Studio",
  "version": "1.3.6",
  "identifier": "ai.axstudio.app",
  "build": {
    "frontendDist": "../web-app/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "IS_TAURI=true IS_DEV=true yarn dev:web",
    "beforeBuildCommand": "IS_TAURI=true yarn build:web"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Ax-Studio",
        "width": 1200,
        "minWidth": 1024,
        "height": 800,
        "minHeight": 740,
        "resizable": true,
        "fullscreen": false,
        "zoomHotkeysEnabled": true,
        "center": true,
        "hiddenTitle": true,
        "transparent": true,
        "trafficLightPosition": {
          "x": 20,
          "y": 32
        },
        "decorations": true,
        "titleBarStyle": "Overlay",
        "windowEffects": {
          "effects": ["fullScreenUI", "mica", "tabbed", "blur", "acrylic"],
          "state": "active"
        },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "capabilities": [
        "default",
        "log-app-window",
        "logs-window",
        "system-monitor-window"
      ],
      "csp": {
        "default-src": "'self' customprotocol: asset: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
        "connect-src": "'self' asset: ipc: data: http://asset.localhost http://ipc.localhost http://127.0.0.1:* http://localhost:* ws://localhost:* ws://127.0.0.1:* https://huggingface.co https://hf.co https://cdn-lfs*.huggingface.co https://*.axstudio.ai https://updates.axstudio.ai https://api.github.com https://api.z.ai https://objects.githubusercontent.com https://github-releases.githubusercontent.com",
        "font-src": [
          "https://fonts.gstatic.com blob: data: tauri://localhost http://tauri.localhost"
        ],
        "img-src": "'self' asset: http://asset.localhost blob: data: https:",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' asset: http://asset.localhost",
        "frame-src": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": ["**/*"]
        }
      }
    }
  },
  "plugins": {
    "os": {
      "version": "latest",
      "resolve": true
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://updates.axstudio.ai/update-check",
        "https://github.com/ax-studio/ax-studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "publisher": "Ax-Studio",
    "active": true,
    "createUpdaterArtifacts": false,
    "icon": ["icons/icon.png"],
    "resources": ["resources/LICENSE"]
  }
}
