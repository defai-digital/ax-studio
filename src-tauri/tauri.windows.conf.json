{
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ax-Studio",
        "width": 1200,
        "minWidth": 1024,
        "height": 800,
        "minHeight": 740,
        "resizable": true,
        "fullscreen": false,
        "zoomHotkeysEnabled": true,
        "center": true,
        "hiddenTitle": true,
        "transparent": false,
        "trafficLightPosition": {
          "x": 20,
          "y": 32
        },
        "decorations": true,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "targets": ["nsis", "msi"],
    "resources": ["resources/pre-install/**/*", "resources/LICENSE"],
    "externalBin": ["resources/bin/bun", "resources/bin/uv"],
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      }
    }
  }
}
