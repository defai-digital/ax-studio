{
  "name": "@ax-studio/assistant-extension",
  "productName": "Ax-Studio Assistant",
  "version": "1.0.2",
  "description": "Powers the default AI assistant that works with all your installed models.",
  "main": "dist/index.js",
  "node": "dist/node/index.js",
  "author": "Ax-Studio",
  "license": "Apache-2.0",
  "homepage": "https://github.com/defai-digital/ax-studio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/defai-digital/ax-studio.git",
    "directory": "extensions/assistant-extension"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "build:publish": "rimraf *.tgz --glob || true && yarn build && npm pack && cp *.tgz ../../pre-install",
    "test": "vitest run"
  },
  "devDependencies": {
    "rimraf": "6.0.1",
    "rolldown": "1.0.0-beta.1",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@ax-studio/core": "../../core/package.tgz"
  },
  "files": [
    "dist/*",
    "package.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "bundleDependencies": [
    "@ax-studio/core"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "packageManager": "yarn@4.5.3"
}
